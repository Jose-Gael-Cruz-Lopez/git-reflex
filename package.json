{
  "name": "git-reflex",
  "private": true,
  "version": "0.0.0",
  "description": "Git Reflex — a git problem gym. Real git in the browser; any command that reaches the goal passes.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0 || true",
    "test": "vitest run || true"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
